# MacroLens Environment Variables
# Copy this file to .env.local and fill in your API keys.
# The app runs fully on rich mock data with NO keys set — always safe for demos.

# ── Data Source Display ────────────────────────────────────────────────────────
# Controls the sidebar footer badge shown on every page.
#   DEMO  → running on rich mock data (default — works with zero config)
#   LIVE  → real FRED + NewsAPI keys are configured and active
NEXT_PUBLIC_DATA_SOURCE=DEMO

# ── Demo Mode Safety Lock ─────────────────────────────────────────────────────
# Set to "true" to force ALL API routes to use rich mock data, regardless of
# which other API keys are set. Recommended for stable public Vercel demos.
# Leave blank (or omit) to allow live API calls when keys are configured.
NEXT_PUBLIC_DEMO_MODE=

# ── AI Layer ──────────────────────────────────────────────────────────────────
# OpenAI API key — enables real GPT-4o-mini in AI Insights chat + Daily Briefing.
# Without this key the app uses keyword-matched mock responses.
# Get a key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Macro Indicators — FRED (Phase 3) ─────────────────────────────────────────
# FRED (Federal Reserve Economic Data) — completely free, no billing required.
# Used to fetch live: CPI YoY, Fed Funds Rate, 10Y Treasury yield,
#                     Unemployment Rate, GDP growth QoQ.
# Register at: https://fred.stlouisfed.org/docs/api/api_key.html
# Fallback: realistic hardcoded mock values if key is not set.
FRED_API_KEY=

# ── News Headlines — NewsAPI (Phase 3) ────────────────────────────────────────
# NewsAPI.org — free developer tier (100 requests/day).
# Used to fetch live macro headlines across inflation, rates, energy, etc.
# Register at: https://newsapi.org/register
# Fallback: 40+ curated mock articles if key is not set.
NEWS_API_KEY=

# ── Market Data ───────────────────────────────────────────────────────────────
# Alpha Vantage — free tier (25 requests/day).
# Used for equity, FX, and bond price signals.
# Register at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# ── Database (optional) ───────────────────────────────────────────────────────
# Supabase — for persistent watchlists and saved alerts (not required for MVP).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
