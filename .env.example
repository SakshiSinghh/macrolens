# MacroLens Environment Variables
# Copy this file to .env.local and fill in your values

# ── Demo Mode ─────────────────────────────────────────────────────────────────
# Set to "true" to lock the app to rich mock data (safe for live demos)
NEXT_PUBLIC_DEMO_MODE=true

# ── AI Layer ──────────────────────────────────────────────────────────────────
# OpenAI API key for AI Insights chat and Morning Briefing generation (Phase 2)
OPENAI_API_KEY=

# ── News Data ─────────────────────────────────────────────────────────────────
# NewsAPI.org — free tier at newsapi.org (Phase 3)
NEWS_API_KEY=

# ── Macro Indicators ──────────────────────────────────────────────────────────
# FRED (Federal Reserve Economic Data) — free at fred.stlouisfed.org/docs/api
FRED_API_KEY=

# ── Market Data ───────────────────────────────────────────────────────────────
# Alpha Vantage — free tier at alphavantage.co (Phase 3)
ALPHA_VANTAGE_API_KEY=

# ── Database (Phase 2+) ───────────────────────────────────────────────────────
# Supabase — if adding persistent storage
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
